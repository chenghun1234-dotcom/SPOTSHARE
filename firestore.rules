rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwnerField(data, fieldName) {
      return signedIn() && data[fieldName] == request.auth.uid;
    }

    function unchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    function ownsSpot(spotId) {
      return signedIn()
        && exists(/databases/$(database)/documents/parking_spots/$(spotId))
        && get(/databases/$(database)/documents/parking_spots/$(spotId)).data.ownerId == request.auth.uid;
    }

    function validAdRequestCreate() {
      return request.resource.data.keys().hasAll(['userId', 'spotId', 'durationDays', 'amount', 'depositCode', 'status'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.spotId is string
        && request.resource.data.durationDays is int
        && request.resource.data.durationDays > 0
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.depositCode is string
        && request.resource.data.depositCode.size() >= 4
        && request.resource.data.status == 'pending'
        && ownsSpot(request.resource.data.spotId);
    }

    match /parking_spots/{spotId} {
      allow read: if true;

      allow create: if isAdmin() || isOwnerField(request.resource.data, 'ownerId');

      allow update: if isAdmin()
        || (isOwnerField(resource.data, 'ownerId')
          && unchanged('ownerId'));

      allow delete: if isAdmin() || isOwnerField(resource.data, 'ownerId');
    }

    match /reservations/{reservationId} {
      allow read: if isAdmin()
        || isOwnerField(resource.data, 'userId')
        || isOwnerField(resource.data, 'ownerId');

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin()
        || (isOwnerField(resource.data, 'userId') && unchanged('userId'))
        || (isOwnerField(resource.data, 'ownerId') && unchanged('userId'));

      allow delete: if isAdmin() || isOwnerField(resource.data, 'userId');
    }

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAdmin() || isOwnerField(resource.data, 'userId');
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if isAdmin();
    }

    match /ad_requests/{adRequestId} {
      allow read: if resource.data.status == 'active'
        || isAdmin()
        || isOwnerField(resource.data, 'userId');

      allow create: if signedIn() && validAdRequestCreate();

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
